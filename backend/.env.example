# Flask 运行环境：development / testing / production
FLASK_ENV=development

# Flask 服务密钥，生产环境请替换为随机强密钥
FLASK_SECRET_KEY=replace-with-your-flask-secret

# JWT 签名密钥，生产环境请替换为随机强密钥
JWT_SECRET_KEY=replace-with-your-jwt-secret

# JWT 有效期，单位：秒
JWT_EXPIRES_SECONDS=7200

# Refresh Token 有效期，单位：秒，默认 7 天
JWT_REFRESH_EXPIRES_SECONDS=604800

# 数据库地址
# SQLite 本地演示：
DATABASE_URL=sqlite:///campus_security.db
# MySQL 示例：
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/campus_security?charset=utf8mb4

# 前端跨域白名单
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
