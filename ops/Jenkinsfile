pipeline {
    agent any
    
    environment {
        DOCKER_IMAGE = "omniguard:${BUILD_NUMBER}"
    }
    
    stages {
        stage('Install Dependencies') {
            parallel {
                stage('Frontend Dependencies') {
                    agent {
                        docker {
                            image 'node:18-alpine'
                            reuseNode true
                        }
                    }
                    steps {
                        dir('frontend') {
                            sh 'npm install'
                        }
                    }
                }
                stage('Backend Dependencies') {
                    agent {
                        docker {
                            image 'python:3.9-slim'
                            reuseNode true
                        }
                    }
                    steps {
                        dir('backend') {
                            sh 'pip install -r requirements.txt'
                            sh 'pip install flake8 pytest pytest-cov'
                        }
                    }
                }
            }
        }
        
        stage('Frontend Lint') {
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps {
                dir('frontend') {
                    sh 'npx eslint src/ || true'
                }
            }
        }
        
        stage('Frontend Build') {
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps {
                dir('frontend') {
                    sh 'npm run build'
                }
            }
        }
        
        stage('Backend Lint') {
            agent {
                docker {
                    image 'python:3.9-slim'
                    reuseNode true
                }
            }
            steps {
                dir('backend') {
                    sh 'python -m flake8 . --config=.flake8 || true'
                }
            }
        }
        
        stage('Backend Check') {
            agent {
                docker {
                    image 'python:3.9-slim'
                    reuseNode true
                }
            }
            steps {
                dir('backend') {
                    sh 'python -m compileall .'
                }
            }
        }
        
        stage('Backend Test') {
            agent {
                docker {
                    image 'python:3.9-slim'
                    reuseNode true
                }
            }
            steps {
                dir('backend') {
                    sh 'mkdir -p tests/reports || true'
                    sh 'python -m pytest tests/ -v --tb=short --cov=. --junitxml=tests/reports/report.xml || true'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'backend/tests/reports/*.xml'
                }
            }
        }
        
        stage('Docker Build') {
            steps {
                script {
                    sh """
                        docker build \\
                            -t ${DOCKER_IMAGE} \\
                            -f docker/Dockerfile .
                    """
                }
            }
        }
    }
    
    post {
        always {
            archiveArtifacts artifacts: 'frontend/dist/**/*', fingerprint: true, allowEmptyArchive: true
            cleanWs()
        }
        
        failure {
            echo '构建失败，请检查日志'
        }
    }
}
