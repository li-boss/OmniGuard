pipeline {
    agent any
    
    environment {
        DOCKER_IMAGE = "omniguard:${BUILD_NUMBER}"
    }
    
    stages {
        stage('Frontend Dependencies') {
            steps {
                script {
                    sh '''
                        docker run --rm --volumes-from jenkins -w $PWD/frontend node:18-alpine sh -c "npm install"
                    '''
                }
            }
        }
        
        stage('Backend Dependencies') {
            steps {
                script {
                    sh '''
                        docker run --rm --volumes-from jenkins -w $PWD/backend python:3.9-slim sh -c "pip install -r requirements.txt && pip install flake8 pytest pytest-cov"
                    '''
                }
            }
        }
        
        stage('Frontend Lint') {
            steps {
                script {
                    sh '''
                        docker run --rm --volumes-from jenkins -w $PWD/frontend node:18-alpine sh -c "npx eslint src/ || true"
                    '''
                }
            }
        }
        
        stage('Frontend Build') {
            steps {
                script {
                    sh '''
                        docker run --rm --volumes-from jenkins -w $PWD/frontend node:18-alpine sh -c "npm run build"
                    '''
                }
            }
        }
        
        stage('Backend Lint') {
            steps {
                script {
                    sh '''
                        docker run --rm --volumes-from jenkins -w $PWD/backend python:3.9-slim sh -c "python -m flake8 . --config=.flake8 || true"
                    '''
                }
            }
        }
        
        stage('Backend Test') {
            steps {
                script {
                    sh '''
                        docker run --rm --volumes-from jenkins -w $PWD/backend python:3.9-slim sh -c "mkdir -p tests/reports && python -m pytest tests/ -v --tb=short || true"
                    '''
                }
            }
        }
        
        stage('Docker Build') {
            steps {
                script {
                    sh """
                        docker build \\
                            -t ${DOCKER_IMAGE} \\
                            -f docker/Dockerfile . || true
                    """
                }
            }
        }
    }
    
    post {
        always {
            archiveArtifacts artifacts: 'frontend/dist/**/*', fingerprint: true, allowEmptyArchive: true
            echo '构建完成'
        }
        
        success {
            echo '✅ 所有阶段执行成功'
        }
        
        failure {
            echo '❌ 构建失败，请检查日志'
        }
    }
}
