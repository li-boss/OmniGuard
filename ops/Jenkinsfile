pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "omniguard:${BUILD_NUMBER}"
        PYTHON_VERSION = "3.11"
        NODE_VERSION = "18"
    }

    stages {
        // 注意：不再写 Checkout 阶段，SCM 会自动拉取

        stage('Install Dependencies') {
            parallel {
                stage('Frontend Dependencies') {
                    steps {
                        dir('frontend') {
                            sh 'npm install'
                        }
                    }
                }
                stage('Backend Dependencies') {
                    steps {
                        dir('backend') {
                            sh 'pip install -r requirements.txt'
                            sh 'pip install flake8 pytest pytest-cov'
                        }
                    }
                }
            }
        }

        stage('Frontend Lint') {
            steps {
                dir('frontend') {
                    sh 'npx eslint src/'
                }
            }
        }

        stage('Frontend Build') {
            steps {
                dir('frontend') {
                    sh 'npm run build'
                }
            }
        }

        stage('Backend Lint') {
            steps {
                dir('backend') {
                    sh 'python -m flake8 . --config=.flake8'
                }
            }
        }

        stage('Backend Check') {
            steps {
                dir('backend') {
                    sh 'python -m compileall .'
                }
            }
        }

        stage('Backend Test') {
            steps {
                dir('backend') {
                    sh 'python -m pytest tests/ -v --tb=short --cov=. --junitxml=tests/reports/report.xml'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'backend/tests/reports/*.xml'
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh """
                    docker build \\
                        -t ${DOCKER_IMAGE} \\
                        -f docker/Dockerfile .
                """
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'frontend/dist/**/*', fingerprint: true
            cleanWs()
        }
        failure {
            emailext(
                subject: "Build Failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "Pipeline failed on branch ${env.BRANCH_NAME}. Check ${env.BUILD_URL}",
                to: "${env.CHANGE_AUTHOR_EMAIL}"
            )
        }
    }
}
