pipeline {
  agent any

  stages {
    stage('Frontend Build') {
      steps {
        dir('frontend') {
          sh 'npm install'
          sh 'npm run build'
        }
      }
    }

    stage('Backend Check') {
      steps {
        dir('backend') {
          sh 'python -m compileall .'
        }
      }
    }
  }
}
